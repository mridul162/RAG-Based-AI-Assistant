{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "title": "Metadata Schema",

  "type": "object",

  "required": [
    "visibility",
    "semantic_domain",
    "created_at",
    "updated_at"
  ],

  "properties": {

    "visibility": {
      "type": "string",

      "enum": [
        "public",
        "private",
        "internal",
        "admin_only"
      ]
    },

    "semantic_domain": {
      "type": "string"
    },

    "aliases": {
      "type": "array",

      "items": {
        "type": "string"
      }
    },

    "tags": {
      "type": "array",

      "items": {
        "type": "string"
      }
    },

    "geo_origin": {
      "type": "object",

      "properties": {

        "region": {
          "type": "string"
        },

        "country": {
          "type": "string"
        }

      }
    },

    "source_type": {
      "type": "string",

      "enum": [
        "markdown",
        "yaml",
        "manual",
        "generated"
      ]
    },

    "created_at": {
      "type": "string",

      "format": "date-time"
    },

    "updated_at": {
      "type": "string",

      "format": "date-time"
    }

  }
}